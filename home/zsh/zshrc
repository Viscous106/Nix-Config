# --- Automatic Python Virtualenv Activation ---
auto_venv_activate() {
  # If venv/bin/activate exists and we are not already in that venv
  if [ -f "venv/bin/activate" ] && [ "$VIRTUAL_ENV" != "$(pwd)/venv" ]; then
    echo "Activating virtual environment..."
# source "venv/bin/activate"  # commented out by conda initialize
  # If a venv is active but we are no longer in its directory tree
  elif [ -n "$VIRTUAL_ENV" ] && [[ ! "$(pwd)/" == "$(dirname $VIRTUAL_ENV)"/* ]]; then
    echo "Deactivating virtual environment..."
    deactivate
  fi
}

# Add the function to the chpwd hook, which runs on every directory change
if [[ -z "${chpwd_functions[(r)auto_venv_activate]}" ]]; then
  chpwd_functions+=(auto_venv_activate)
fi
# --- End Automatic Python Virtualenv Activation ---

